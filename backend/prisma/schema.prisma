// Ortak Doku — veri modeli (mockup.html iş modeline göre revize, 2026-06-22)
// Detay/gerekçe: kök dizindeki BACKEND-ANALIZ.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

// Roller = üyelik tier'ı (mockup). USER 2× fiyat, TEAM_* 1× fiyat.
enum Role {
  USER // Kullanıcı (ücretsiz, 2× fiyat)
  TEAM_MEMBER // Ekip Üyesi ($30/ay aidat, 1× fiyat, bir lidere bağlı)
  TEAM_LEADER // Ekip Lideri (aidatsız, 1× fiyat, üyelerini yönetir)
  ADMIN // Platform yöneticisi
  PRODUCTION // Üretim ekibi
}

enum ProductCategory {
  WALLPAPER // m² bazlı
  WALL_DECAL // flat
  WOOD // flat (CNC oyma)
}

enum ProductUnit {
  M2 // metrekare bazlı fiyat
  FLAT // sabit fiyat (adet)
}

enum OrderStatus {
  RECEIVED
  IN_PRODUCTION
  AWAITING_APPROVAL
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  BALANCE // ön yüklü bakiye
  CARD // kredi kartı
}

enum OrderSource {
  MANUAL
  ETSY
}

enum AssetStatus {
  UPLOADING
  READY
  PROCESSING
  FAILED
}

enum AssetRole {
  PRODUCTION // üretim dosyası (PDF/AI/EPS/PNG, ≤500MB)
  MOCKUP // ölçülü kontrol görseli (JPG/PNG)
  SHIPPING_LABEL // kargo etiketi (PDF/JPG/PNG)
  OTHER
}

enum LifecycleStage {
  HOT
  ARCHIVE
  PURGED
}

enum TransactionType {
  BALANCE_LOAD // bakiye yükleme
  ORDER_PAYMENT // sipariş ödemesi
  MEMBERSHIP_FEE // $30 aidat
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BillingCountry {
  TR
  US
}

enum BillingType {
  INDIVIDUAL
  CORPORATE
}

enum OtpPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// ─────────────────────────────────────────────
// Organization (opsiyonel — çok-kullanıcılı firma için korundu)
// ─────────────────────────────────────────────

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String?  @unique // subdomain (bayi1.ortakdoku.com → "bayi1")
  theme                Json? // tenant branding (renk/logo/hero)
  taxInfo              String?
  quickbooksCustomerId String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users User[]
}

// ─────────────────────────────────────────────
// User (merkez varlık)
// ─────────────────────────────────────────────

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  fullName               String?
  phone                  String?
  role                   Role     @default(USER)
  priceMultiplier        Int      @default(2) // USER=2, TEAM_*=1
  balance                Decimal  @default(0) @db.Decimal(12, 2) // USD bakiye
  hasDiscount40          Boolean  @default(false) // $250 yükleme sonrası
  isEmailVerified        Boolean  @default(false)
  // 2FA (TOTP / authenticator QR)
  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String? // AES-GCM şifreli base32 secret
  twoFactorRecoveryCodes String[] // bcrypt-hashed yedek kodlar
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Ekip hiyerarşisi: üye → lider (self-relation)
  leaderId String?
  leader   User?   @relation("TeamHierarchy", fields: [leaderId], references: [id])
  members  User[]  @relation("TeamHierarchy")

  // Opsiyonel firma bağlantısı
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  etsyStores         EtsyStore[]
  billingInfo        BillingInfo?
  membership         Membership?
  orders             Order[]             @relation("OrderOwner")
  createdOrders      Order[]             @relation("OrderCreatedBy")
  transactions       Transaction[]
  creditLedger       CreditLedger[]
  devices            UserDevice[]
  // Topluluk & eğitim (PDF Ekip Üyesi vaatleri)
  courseEnrollments  CourseEnrollment[]
  consultingRequests ConsultingRequest[]
  eventRegistrations EventRegistration[]
  networkProfile     NetworkProfile?
  returnRequests     ReturnRequest[]
}

// ─────────────────────────────────────────────
// Bildirim (push cihaz + log)
// ─────────────────────────────────────────────

model UserDevice {
  id           String   @id @default(cuid())
  deviceToken  String   @unique // OneSignal subscription/player id
  platform     String // IOS | ANDROID | WEB
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model PushNotificationLog {
  id              String    @id @default(cuid())
  title           String
  body            String
  data            Json?
  targetType      String // ALL | USER_IDS | SEGMENT
  targetIds       String[]
  totalRecipients Int       @default(0)
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  status          String    @default("PENDING") // PENDING | SENT | FAILED
  providerMsgId   String?
  errorMessage    String?
  sentAt          DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
}

model OtpCode {
  id         String     @id @default(cuid())
  email      String
  codeHash   String
  purpose    OtpPurpose @default(EMAIL_VERIFY)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([email, purpose])
}

// ─────────────────────────────────────────────
// Etsy mağaza & fatura & üyelik
// ─────────────────────────────────────────────

model EtsyStore {
  id        String   @id @default(cuid())
  name      String
  apiKey    String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders Order[]
}

model BillingInfo {
  id           String         @id @default(cuid())
  country      BillingCountry
  type         BillingType
  address      String?
  // TR
  tc           String? // bireysel TC (11)
  companyTitle String? // kurumsal ünvan
  taxOffice    String?
  taxNo        String? // (10)
  // US
  ssn          String? // bireysel SSN/ITIN
  ein          String? // kurumsal EIN
  state        String? // kayıtlı eyalet
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Membership {
  id          String    @id @default(cuid())
  tier        Role // TEAM_MEMBER / TEAM_LEADER / USER
  monthlyFee  Decimal   @default(0) @db.Decimal(12, 2)
  active      Boolean   @default(true)
  startedAt   DateTime  @default(now())
  renewalDate DateTime?
  leaderId    String? // TEAM_MEMBER için bağlı lider

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String            @id @default(cuid())
  type      TransactionType
  amount    Decimal           @db.Decimal(12, 2)
  status    TransactionStatus @default(SUCCESS)
  method    PaymentMethod?
  orderId   String?
  note      String?
  createdAt DateTime          @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt]) // kullanıcı işlem geçmişi (P1 perf)
}

// ─────────────────────────────────────────────
// Katalog & Fiyatlandırma
// ─────────────────────────────────────────────

model Material {
  id        String   @id @default(cuid())
  name      String
  widthInch Int?
  settings  Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id              String          @id @default(cuid())
  name            String
  category        ProductCategory
  unit            ProductUnit     @default(M2)
  description     String?
  imageUrl        String? // vitrin/landing görseli (admin yönetir)
  basePricePerM2  Decimal?        @db.Decimal(12, 4) // M2 ürünler için (1× fiyat)
  flatPrice       Decimal?        @db.Decimal(12, 2) // FLAT ürünler için (1× fiyat)
  subTypes        Json? // wallpaper alt türleri: [{key,label}]
  active          Boolean         @default(true)
  // Baskı dosya gereksinimleri (H3/#34) — yükleme öncesi/sonrası doğrulama
  minDpi          Int? // gerekli minimum çözünürlük (örn. 150)
  requiredFormats String[]        @default([]) // izinli formatlar: ['tiff','pdf']
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  materialId String?
  material   Material? @relation(fields: [materialId], references: [id])

  orderItems OrderItem[]
}

// Sipariş ek seçenekleri (Shipping Box, Installation Kit, Sample)
model ExtraOption {
  id              String   @id @default(cuid())
  code            String   @unique // SHIPPING_BOX | INSTALLATION_KIT | SAMPLE
  name            String
  price           Decimal  @db.Decimal(12, 2)
  fixedWidthInch  Decimal? @db.Decimal(10, 2) // Sample → 20
  fixedHeightInch Decimal? @db.Decimal(10, 2) // Sample → 15
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  orderExtras OrderExtra[]
}

// ─────────────────────────────────────────────
// Sipariş
// ─────────────────────────────────────────────

model Order {
  id            String          @id @default(cuid())
  orderNumber   String          @unique @default(cuid())
  category      ProductCategory
  productType   String? // wallpaper alt türü (Peel&Stick Smooth, vb.)
  status        OrderStatus     @default(RECEIVED)
  paymentStatus PaymentStatus   @default(PENDING)
  paymentMethod PaymentMethod   @default(BALANCE)
  source        OrderSource     @default(MANUAL)

  // Tutarlar
  subtotal    Decimal @default(0) @db.Decimal(12, 2) // ürün/m² bedeli (extralar hariç)
  extrasTotal Decimal @default(0) @db.Decimal(12, 2)
  discount40  Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @default(0) @db.Decimal(12, 2)
  totalSqm    Decimal @default(0) @db.Decimal(12, 4)

  boardPosition Int @default(0) // Kanban kolon (status) içi sıra

  // Etsy / referanslar
  etsyOrderNo         String?
  orderDate           DateTime?
  quickbooksInvoiceId String?
  paymentProvider     String? // QUICKBOOKS | STRIPE (kart ödemesi)
  paymentRef          String? // sağlayıcı referansı (invoice/checkout id)

  // Teslimat
  clientName    String?
  clientAddress String?
  clientCountry String?
  clientCity    String?
  clientState   String?
  clientZip     String?
  clientPhone   String?
  clientNote    String?
  clientLat     Float? // harita/canlı aktivite (#15)
  clientLng     Float?

  // Kargo / takip (operasyon — carrier API hazır; manuel takip no ile çalışır)
  carrier             String? // UPS | FedEx | USPS | DHL ...
  trackingNumber      String?
  shippedAt           DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?
  shippingCost        Decimal   @default(0) @db.Decimal(12, 2)

  archivedAt DateTime? // arşiv (#13) — null değilse arşivlenmiş

  // Üretim-öncesi onay penceresi (H2/#33) — onaylanmadan IN_PRODUCTION'a geçemez
  approvedAt       DateTime?
  approvedByUserId String?

  // Numune sipariş (D2/#41) — bayiye düşük maliyetli fiziksel örnek
  isSample Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation("OrderOwner", fields: [userId], references: [id])

  createdByUserId String?
  createdBy       User?   @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])

  organizationId String?

  etsyStoreId String?
  etsyStore   EtsyStore? @relation(fields: [etsyStoreId], references: [id])

  items        OrderItem[]
  extras       OrderExtra[]
  assets       Asset[]
  statusEvents OrderStatusEvent[]
  returns      ReturnRequest[]

  @@index([status, boardPosition])
  @@index([userId]) // bayi siparişleri (P1 perf)
  @@index([organizationId])
  @@index([archivedAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Ayarlar (key-value) & Denetim kaydı
// ─────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String?
  action      String // ORDER_STATUS_CHANGE | CREDIT_TOPUP | MEMBERSHIP_UPGRADE | SETTING_UPDATE | ORDER_CREATE ...
  entityType  String?
  entityId    String?
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  widthInch  Decimal @db.Decimal(10, 2)
  heightInch Decimal @db.Decimal(10, 2)
  widthCm    Decimal @db.Decimal(10, 2)
  heightCm   Decimal @db.Decimal(10, 2)
  sqft       Decimal @db.Decimal(12, 4)
  sqm        Decimal @db.Decimal(12, 4)
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  lineTotal  Decimal @db.Decimal(12, 2)
  notes      String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model OrderExtra {
  id       String  @id @default(cuid())
  name     String // snapshot
  price    Decimal @db.Decimal(12, 2)
  quantity Int     @default(1)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  extraOptionId String?
  extraOption   ExtraOption? @relation(fields: [extraOptionId], references: [id])
}

model OrderStatusEvent {
  id         String       @id @default(cuid())
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  byUserId   String?
  createdAt  DateTime     @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Dosya (R2 metadata)
// ─────────────────────────────────────────────

model Asset {
  id             String         @id @default(cuid())
  r2Key          String         @unique
  originalName   String
  mime           String?
  sizeBytes      BigInt?
  role           AssetRole      @default(OTHER)
  status         AssetStatus    @default(UPLOADING)
  lifecycleStage LifecycleStage @default(HOT)
  thumbnailKey   String?
  dpi            Int?
  widthPx        Int?
  heightPx       Int?
  checks         Json?
  uploadId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  userId String?
}

// ─────────────────────────────────────────────
// Kredi / Bakiye defteri (kullanıcı bazlı)
// ─────────────────────────────────────────────

model CreditLedger {
  id           String   @id @default(cuid())
  delta        Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal  @db.Decimal(12, 2)
  reason       String
  orderId      String?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Document yönetimi (sipariş/bayi belgeleri — R2)
// ─────────────────────────────────────────────
model Document {
  id               String   @id @default(cuid())
  fileName         String
  r2Key            String   @unique
  mimeType         String?
  sizeBytes        Int?
  category         String   @default("GENERAL") // ORDER | DEALER | GENERAL
  orderId          String?
  userId           String?
  organizationId   String?
  uploadedByUserId String
  createdAt        DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([organizationId])
}

// ─────────────────────────────────────────────
// Ticket / destek
// ─────────────────────────────────────────────
enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Ticket {
  id               String          @id @default(cuid())
  subject          String
  status           TicketStatus    @default(OPEN)
  priority         TicketPriority  @default(NORMAL)
  userId           String // açan
  organizationId   String?
  orderId          String?
  assignedToUserId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  messages         TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUserId String
  body         String
  internal     Boolean  @default(false) // yalnız staff görür
  createdAt    DateTime @default(now())

  @@index([ticketId])
}

// ─────────────────────────────────────────────
// Bildirim merkezi (in-app) + tercihler
// ─────────────────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // ORDER_STATUS | TICKET | SYSTEM ...
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  email        Boolean  @default(true)
  push         Boolean  @default(true)
  orderUpdates Boolean  @default(true)
  marketing    Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Dijital proof onayı (H1-proof/#35) — baskı öncesi bayi/müşteri onayı
// ─────────────────────────────────────────────
enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model Proof {
  id                String      @id @default(cuid())
  orderId           String
  fileName          String
  r2Key             String?
  note              String? // staff açıklaması
  status            ProofStatus @default(PENDING)
  createdByUserId   String // proof'u yükleyen personel
  respondedByUserId String? // onaylayan/reddeden bayi
  respondedAt       DateTime?
  responseNote      String?
  createdAt         DateTime    @default(now())

  @@index([orderId, status])
}

// ─────────────────────────────────────────────
// Partner API: dışa açık imzalı webhook abonelikleri (O2/#37)
// ─────────────────────────────────────────────
model WebhookSubscription {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  url            String
  secret         String // HMAC-SHA256 imzalama
  events         String[] @default([]) // ['order.status_changed', 'proof.responded', ...]
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// Kapasite-bazlı iç üretim routing (O5/#39)
// ─────────────────────────────────────────────
enum ProductionStation {
  PRINT // TIFF büyük format baskı (wallpaper)
  CNC // ahşap oyma
  CUT // kesim (decal)
  PACK // paketleme
}

enum ProductionJobStatus {
  QUEUED
  IN_PROGRESS
  DONE
}

model ProductionJob {
  id        String              @id @default(cuid())
  orderId   String
  station   ProductionStation
  status    ProductionJobStatus @default(QUEUED)
  priority  Boolean             @default(false) // üst plan bayilerine öncelik (D1/#40)
  note      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([station, status])
  @@index([orderId])
}

// ─────────────────────────────────────────────
// EĞİTİM (PDF: Platform/Dijital Reklam/Sosyal Medya/Ticaret-Finans — Ekip Üyesi %50)
// ─────────────────────────────────────────────

enum CourseCategory {
  PLATFORM // Platform Eğitimleri
  DIGITAL_ADS // Dijital Reklam Yönetimi
  SOCIAL_MEDIA // Sosyal Medya Yönetimi
  TRADE_FINANCE // Ticaret ve Finans
  OTHER
}

model Course {
  id          String         @id @default(cuid())
  title       String
  titleEn     String?
  summary     String? // kısa açıklama (kart)
  description String? // uzun açıklama
  category    CourseCategory @default(OTHER)
  level       String? // Başlangıç / Orta / İleri
  price       Decimal        @default(0) @db.Decimal(12, 2) // standart fiyat (USD); Ekip Üyesi %50
  durationMin Int? // toplam süre (dk)
  lessonCount Int? // ders sayısı
  imageUrl    String?
  contentUrl  String? // video/içerik erişim linki (kayıt sonrası)
  active      Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  enrollments CourseEnrollment[]

  @@index([active, category])
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  paidPrice Decimal  @db.Decimal(12, 2) // ödenen (üye indirimi uygulanmış) tutar
  isMember  Boolean  @default(false) // kayıt anında Ekip Üyesi miydi (%50)
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// DANIŞMANLIK (PDF: uzman ekip ile birebir görüşme — Ekip Üyesi ücretsiz)
// ─────────────────────────────────────────────

enum ConsultingStatus {
  PENDING // talep alındı
  SCHEDULED // randevu verildi
  COMPLETED // tamamlandı
  CANCELLED
}

model ConsultingRequest {
  id          String           @id @default(cuid())
  userId      String
  topic       String // konu başlığı
  details     String? // talep detayı
  preferredAt DateTime? // bayinin tercih ettiği zaman
  status      ConsultingStatus @default(PENDING)
  scheduledAt DateTime? // admin'in verdiği randevu
  meetingUrl  String? // görüşme linki
  adminNote   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// ETKİNLİKLER (PDF: seminer/workshop/buluşma — Ekip Üyesi %50 indirimli)
// ─────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  titleEn     String?
  description String?
  type        String? // seminer | workshop | buluşma | webinar
  startsAt    DateTime
  endsAt      DateTime?
  isOnline    Boolean   @default(true)
  location    String? // online linki / fiziksel adres
  capacity    Int? // kontenjan (null = sınırsız)
  price       Decimal   @default(0) @db.Decimal(12, 2) // USD; Ekip Üyesi %50
  imageUrl    String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  registrations EventRegistration[]

  @@index([active, startsAt])
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  paidPrice Decimal  @default(0) @db.Decimal(12, 2)
  isMember  Boolean  @default(false)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// NETWORKING (PDF: güçlü iş ağı — opt-in üye dizini)
// ─────────────────────────────────────────────

model NetworkProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  headline    String? // tek satır tanıtım
  bio         String?
  company     String?
  website     String?
  location    String?
  expertise   String[] @default([]) // uzmanlık etiketleri
  visible     Boolean  @default(true) // dizinde görünür mü
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([visible])
}

// ─────────────────────────────────────────────
// İADE / RMA (operasyon — kolay iade akışı)
// ─────────────────────────────────────────────

enum ReturnStatus {
  REQUESTED // talep oluşturuldu
  APPROVED // onaylandı
  REJECTED // reddedildi
  RECEIVED // ürün teslim alındı
  REFUNDED // ücret iade edildi (cüzdan)
  REPRINTED // yeniden baskı yapıldı
}

enum ReturnReason {
  DEFECT // kusurlu/hatalı baskı
  WRONG_ITEM // yanlış ürün
  DAMAGED // kargoda hasar
  NOT_AS_DESC // açıklamaya uymuyor
  OTHER
}

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String
  userId       String
  reason       ReturnReason @default(OTHER)
  details      String?
  status       ReturnStatus @default(REQUESTED)
  resolution   String? // reprint | refund | note
  refundAmount Decimal?     @db.Decimal(12, 2)
  refundedAt   DateTime? // para iadesi yapıldığı an — idempotency kilidi (bir kez kredilenir)
  adminNote    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
  @@index([status])
}
