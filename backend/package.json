{
  "name": "printy-backend",
  "version": "0.1.0",
  "description": "Printy — Print-on-Demand order & production platform (Faz 1 backend)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.development -- prisma studio",
    "db:seed": "dotenv -e .env.development -- ts-node prisma/seed.ts",
    "db:backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@bull-board/api": "^6.21.3",
    "@bull-board/express": "^6.21.3",
    "@bull-board/nestjs": "^6.21.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.79.1",
    "bwip-js": "^4.11.1",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "express-basic-auth": "^1.2.1",
    "joi": "^17.13.3",
    "nodemailer": "^6.9.15",
    "otplib": "^12.0.1",
    "papaparse": "^5.5.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^6.4.16",
    "@types/papaparse": "^5.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
