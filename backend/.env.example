# ── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Frontend origin(s) for CORS, comma-separated
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────
# DEV: docker-compose host portu 5433 (5432 makinende doluydu):
DATABASE_URL=postgresql://printy:printy@localhost:5433/printy?schema=public
# PROD (yönetilen PG, Neon/RDS/DO): SSL zorunlu →
#   postgresql://USER:PASS@HOST:5432/printy?schema=public&sslmode=require

# ── Redis (BullMQ + cache) ─────────────────────────────
# DEV: docker host portu 6380:
REDIS_URL=redis://localhost:6380
# PROD (yönetilen Redis, Upstash/Redis Cloud): TLS → rediss:// + eviction=noeviction
#   rediss://default:PASS@HOST:PORT

# ── Auth (JWT) ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
# At-rest şifreleme (2FA secret/PII) — openssl rand -hex 32
ENCRYPTION_KEY=

# ── Cloudflare R2 (S3 uyumlu object storage) ───────────
# R2 paneli → Manage R2 API Tokens → Access Key / Secret
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret
R2_BUCKET=printy-files
# Endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# İmzalı upload/download URL geçerlilik süresi (saniye)
R2_PRESIGN_EXPIRES=3600

# ── SMTP (OTP + toplu e-posta) — boşsa dev'de log'a yazılır ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Ortak Doku <noreply@ortakdoku.com>

# ── OneSignal push (kendi app'in; boşsa push gönderilmez) ──────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
