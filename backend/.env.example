# ── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Frontend origin(s) for CORS, comma-separated
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ──────────────────────────────
# docker-compose host portu 5433 (5432 makinende doluydu):
DATABASE_URL=postgresql://printy:printy@localhost:5433/printy?schema=public

# ── Redis (Faz 2 BullMQ) — docker host portu 6380 ─────
REDIS_URL=redis://localhost:6380

# ── Auth (JWT) ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# ── Cloudflare R2 (S3 uyumlu object storage) ───────────
# R2 paneli → Manage R2 API Tokens → Access Key / Secret
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret
R2_BUCKET=printy-files
# Endpoint: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# İmzalı upload/download URL geçerlilik süresi (saniye)
R2_PRESIGN_EXPIRES=3600
